{
  "name": "@apollogeddon/forgejs",
  "version": "2.0.3",
  "description": "Quality control library for maintaining best practice nodejs",
  "author": "apollogeddon",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apollogeddon/forgejs.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": "./dist/index.js",
  "exports": {
    "./biome.json": "./biome.json",
    "./commitlint.config.cjs": {
      "types": "./commitlint.config.d.ts",
      "import": "./commitlint.config.cjs"
    },
    "./snodeb.config.cjs": {
      "types": "./snodeb.config.d.ts",
      "import": "./snodeb.config.cjs"
    },
    "./tsup.config.cjs": {
      "types": "./tsup.config.d.ts",
      "import": "./tsup.config.cjs"
    },
    "./vitest.config.cjs": {
      "types": "./vitest.config.d.ts",
      "import": "./vitest.config.cjs"
    },
    "./tsconfig.json": "./tsconfig.json"
  },
  "files": [
    "dist",
    "biome.json",
    "commitlint.config.cjs",
    "commitlint.config.d.ts",
    "lefthook.yml",
    "tsup.config.cjs",
    "tsup.config.d.ts",
    "snodeb.config.cjs",
    "snodeb.config.d.ts",
    "vitest.config.cjs",
    "vitest.config.d.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "watch": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "biome check --fix",
    "type": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "publint": "publint",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "lefthook": "2.1.8",
    "publint": "0.3.21",
    "snodeb": "1.1.4",
    "tsup": "8.5.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "js-yaml": "4.1.1"
  }
}
