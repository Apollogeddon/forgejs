{
  "name": "@apollogeddon/forgejs",
  "version": "2.2.1",
  "description": "Quality control library for maintaining best practice nodejs",
  "author": "apollogeddon",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apollogeddon/forgejs.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "forgejs": "./dist/index.js"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "./configs/biome.json": "./configs/biome.json",
    "./commitlint.config.cjs": {
      "types": "./configs/commitlint.config.d.ts",
      "import": "./configs/commitlint.config.cjs"
    },
    "./snodeb.config.cjs": {
      "types": "./configs/snodeb.config.d.ts",
      "import": "./configs/snodeb.config.cjs"
    },
    "./tsup.config.cjs": {
      "types": "./configs/tsup.config.d.ts",
      "import": "./configs/tsup.config.cjs"
    },
    "./vitest.config.cjs": {
      "types": "./configs/vitest.config.d.ts",
      "import": "./configs/vitest.config.cjs"
    },
    "./configs/tsconfig.json": "./configs/tsconfig.json"
  },
  "files": [
    "dist",
    "configs",
    "lefthook.yml"
  ],
  "scripts": {
    "watch": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "biome check --fix",
    "type": "tsc --noEmit",
    "build": "tsup --config configs/tsup.config.cjs",
    "test": "vitest run --config configs/vitest.config.cjs",
    "publint": "publint",
    "prepare": "lefthook install || true",
    "prepublishOnly": "npm run build && npm run type && npm run test && npm run publint"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "lefthook": "2.1.8",
    "publint": "0.3.21",
    "snodeb": "1.1.4",
    "tsup": "8.5.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "js-yaml": "4.1.1"
  }
}
