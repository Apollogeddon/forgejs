{
  "name": "@apollogeddon/forgejs",
  "version": "1.3.0",
  "description": "Quality control library for maintaining best practice nodejs",
  "author": "apollogeddon",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apollogeddon/forgejs.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": "./dist/index.js",
  "exports": {
    "./biome.json": "./biome.json",
    "./commitlint.config.cjs": {
      "types": "./commitlint.config.d.ts",
      "import": "./commitlint.config.cjs"
    },
    "./snodeb.config.cjs": {
      "types": "./snodeb.config.d.ts",
      "import": "./snodeb.config.cjs"
    },
    "./tsup.config.cjs": {
      "types": "./tsup.config.d.ts",
      "import": "./tsup.config.cjs"
    },
    "./astro.config.mjs": {
      "types": "./astro.config.d.ts",
      "import": "./astro.config.mjs"
    },
    "./vitest.config.cjs": {
      "types": "./vitest.config.d.ts",
      "import": "./vitest.config.cjs"
    },
    "./tsconfig.json": "./tsconfig.json"
  },
  "files": [
    "dist",
    "biome.json",
    "commitlint.config.cjs",
    "commitlint.config.d.ts",
    "lefthook.yml",
    "tsup.config.cjs",
    "tsup.config.d.ts",
    "astro.config.mjs",
    "astro.config.d.ts",
    "snodeb.config.cjs",
    "snodeb.config.d.ts",
    "vitest.config.cjs",
    "vitest.config.d.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "watch": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "biome check --fix",
    "type": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "docs:init": "astro sync",
    "docs:build": "astro build",
    "docs:watch": "astro dev",
    "publint": "publint",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.6",
    "lefthook": "2.1.8",
    "publint": "0.3.21",
    "snodeb": "1.1.4",
    "tsup": "8.5.1",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.6"
  },
  "optionalDependencies": {
    "@astrojs/starlight": "0.39.2",
    "@astrojs/starlight-tailwind": "^3.0.1",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "5.18.0",
    "sharp": "0.34.5",
    "starlight-typedoc": "0.22.0",
    "tailwindcss": "^3.4.19",
    "typedoc": "0.28.19"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "js-yaml": "4.1.1"
  }
}
