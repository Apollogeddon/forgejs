{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [],
  "groupOrder": ["Functions", "Payload Format", "*", "Variables"],
  "highlightLanguages": [
    "bash",
    "console",
    "css",
    "html",
    "javascript",
    "json",
    "jsonc",
    "json5",
    "mermaid",
    "yaml",
    "tsx",
    "typescript"
  ],
  "plugin": ["typedoc-plugin-coverage"],
  "requiredToBeDocumented": ["Enum", "Function", "Class", "Interface", "TypeAlias"]
}
