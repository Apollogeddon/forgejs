---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Base from "./Base.astro";

interface Props {
  title: string;
  description?: string;
  currentSlug: string;
}

const { title, description, currentSlug } = Astro.props;
---

<Base title={`${title} · Forge.js`} description={description}>
  <Header />

  <div class="flex">
    <aside
      class="sticky top-16 h-[calc(100vh-4rem)] w-64 shrink-0 overflow-y-auto border-r border-zinc-800 bg-zinc-950 px-4 pb-12 pt-6"
    >
      <Sidebar currentSlug={currentSlug} />
    </aside>

  <main class="min-w-0 flex-1 px-4 pb-24 pt-10 sm:px-6 md:px-12">
    <article class="prose prose-invert mx-auto max-w-3xl">
      <h1
        class="mb-1 text-3xl font-extrabold tracking-tight text-zinc-50 sm:text-4xl"
      >
        {title}
      </h1>
      {
        description && (
          <p class="mt-2 mb-8 text-lg leading-relaxed text-zinc-400 not-prose">
            {description}
          </p>
        )
      }
      <slot />
    </article>
  </main>
  </div>

</Base>
