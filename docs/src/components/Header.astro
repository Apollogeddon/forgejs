---

<header
  class="sticky top-0 z-40 h-16 w-full border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md"
>
  <div class="mx-auto flex h-full max-w-7xl items-center gap-3 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <img
        src="/forgejs.svg"
        alt="Forge.js"
        width="32"
        height="32"
        class="h-8 w-8 rounded-md"
      />
      <span class="text-base font-bold tracking-tight text-zinc-50"
        >Forge.js</span
      >
    </a>

    <nav class="ml-4 hidden items-center gap-6 text-sm sm:flex">
      <a
        href="/docs/getting-started"
        class="font-medium text-zinc-400 transition-colors hover:text-zinc-100"
        >Docs</a
      >
    </nav>

    <div class="ml-auto">
      <a
        href="https://github.com/apollogeddon/forgejs"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-1.5 text-sm font-medium text-zinc-200 transition-colors hover:border-zinc-600 hover:bg-zinc-800"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
