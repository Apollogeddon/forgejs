{
  "root": false,
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@apollogeddon/forgejs/configs/biome.json"],
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
